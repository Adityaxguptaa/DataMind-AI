modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23331
externalPort = 3000

[userenv]

[userenv.shared]
JWT_ALGORITHM = "HS256"
JWT_EXPIRY_MINUTES = "1440"
UPLOAD_DIR = "uploads"
REPORTS_DIR = "reports"
MAX_FILE_SIZE_MB = "50"
CORS_ORIGINS = "*"
# Store ALL secrets in Replit Secrets panel, not here:
# REDIS_URL, UPSTASH_REDIS_URL, NEON_DATABASE_URL, NEON_SYNC_DATABASE_URL,
# GEMINI_API_KEY, HUGGINGFACE_TOKEN, JWT_SECRET_KEY, SESSION_SECRET, GROQ_API_KEY

[nix]
channel = "stable-25_05"
packages = ["cargo", "freetype", "glibcLocales", "gumbo", "harfbuzz", "jbig2dec", "lcms2", "libiconv", "libimagequant", "libjpeg", "libjpeg_turbo", "libtiff", "libwebp", "libxcrypt", "mupdf", "openjpeg", "pkg-config", "postgresql", "rustc", "swig", "tcl", "tk", "xcbuild", "xsimd", "zlib"]
